{% extends 'base.html.twig' %}

{% block title %}Compétences - Programmation{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto">
    <div class="mb-8">
        <a href="{{ path('app_competences') }}" class="inline-flex items-center text-sm text-slate-500 hover:text-blue-600 transition-colors mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
            </svg>
            Retour aux compétences
        </a>
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900">Programmation & Développement</h2>
        <p class="text-slate-600 mt-2">Mon expertise en développement logiciel, web et gestion de données.</p>
    </div>

    <div class="grid gap-8">
        <!-- Langages & Frameworks -->
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center gap-3">
                <span class="text-2xl">💻</span>
                <h3 class="text-lg font-semibold text-slate-900">Langages & Frameworks</h3>
            </div>
            <div class="p-6 grid gap-6 md:grid-cols-2">
                <!-- HTML/CSS -->
                <div class="space-y-3">
                    <div class="flex items-center gap-2">
                        <span class="px-2 py-1 text-xs font-semibold bg-orange-100 text-orange-700 rounded">HTML / CSS</span>
                    </div>
                    <ul class="space-y-2">
                        <li class="flex items-start gap-2 text-sm text-slate-600">
                            <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                            <span>Création de sites web modernes et responsives</span>
                        </li>
                    </ul>
                </div>

                <!-- Python/FastAPI -->
                <div class="space-y-3">
                    <div class="flex items-center gap-2">
                        <span class="px-2 py-1 text-xs font-semibold bg-blue-100 text-blue-700 rounded">Python / FastAPI</span>
                    </div>
                    <ul class="space-y-2">
                        <li class="flex items-start gap-2 text-sm text-slate-600">
                            <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                            <span>Algorithmique et manipulation de données</span>
                        </li>
                        <li class="flex items-start gap-2 text-sm text-slate-600">
                            <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                            <span>Traitement de listes et structures complexes</span>
                        </li>
                        <li class="flex items-start gap-2 text-sm text-slate-600">
                            <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                            <span>Développement d'API avec FastAPI</span>
                        </li>
                    </ul>
                </div>

                <!-- JavaScript -->
                <div class="space-y-3">
                    <div class="flex items-center gap-2">
                        <span class="px-2 py-1 text-xs font-semibold bg-yellow-100 text-yellow-700 rounded">JavaScript / Next.js</span>
                    </div>
                    <ul class="space-y-2">
                        <li class="flex items-start gap-2 text-sm text-slate-600">
                            <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                            <span>Interactivité et manipulation du DOM</span>
                        </li>
                        <li class="flex items-start gap-2 text-sm text-slate-600">
                            <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                            <span>Routing et composants React/Next.js</span>
                        </li>
                        <li class="flex items-start gap-2 text-sm text-slate-600">
                            <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                            <span>Consommation d'API (Fetch)</span>
                        </li>
                    </ul>
                </div>

                <!-- PHP/Symfony -->
                <div class="space-y-3">
                    <div class="flex items-center gap-2">
                        <span class="px-2 py-1 text-xs font-semibold bg-indigo-100 text-indigo-700 rounded">PHP / Symfony</span>
                    </div>
                    <ul class="space-y-2">
                        <li class="flex items-start gap-2 text-sm text-slate-600">
                            <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                            <span>Architecture MVC et POO</span>
                        </li>
                        <li class="flex items-start gap-2 text-sm text-slate-600">
                            <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                            <span>Gestion de base de données (Doctrine ORM)</span>
                        </li>
                        <li class="flex items-start gap-2 text-sm text-slate-600">
                            <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                            <span>Sécurité et formulaires</span>
                        </li>
                    </ul>
                </div>

                <!-- C# -->
                <div class="space-y-3">
                    <div class="flex items-center gap-2">
                        <span class="px-2 py-1 text-xs font-semibold bg-purple-100 text-purple-700 rounded">C#</span>
                    </div>
                    <ul class="space-y-2">
                        <li class="flex items-start gap-2 text-sm text-slate-600">
                            <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                            <span>Programmation orientée objet</span>
                        </li>
                        <li class="flex items-start gap-2 text-sm text-slate-600">
                            <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                            <span>Création graphique 2D/3D</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
            <!-- Bases de données -->
            <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center gap-3">
                    <span class="text-2xl">🗄️</span>
                    <h3 class="text-lg font-semibold text-slate-900">Bases de données</h3>
                </div>
                <div class="p-6">
                    <div class="space-y-3">
                        <div class="flex items-center gap-2">
                            <span class="px-2 py-1 text-xs font-semibold bg-slate-200 text-slate-700 rounded">SQL</span>
                        </div>
                        <ul class="space-y-2">
                            <li class="flex items-start gap-2 text-sm text-slate-600">
                                <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                                <span>Requêtes avancées (jointures, agrégations)</span>
                            </li>
                            <li class="flex items-start gap-2 text-sm text-slate-600">
                                <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                                <span>Gestion et modification de bases de données</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Git & GitHub -->
            <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center gap-3">
                    <span class="text-2xl">🐙</span>
                    <h3 class="text-lg font-semibold text-slate-900">Git & GitHub</h3>
                </div>
                <div class="p-6">
                    <ul class="space-y-2">
                        <li class="flex items-start gap-2 text-sm text-slate-600">
                            <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                            <span>Création et gestion d’arborescences de projets</span>
                        </li>
                        <li class="flex items-start gap-2 text-sm text-slate-600">
                            <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                            <span>Clonage, fusion et gestion de branches</span>
                        </li>
                        <li class="flex items-start gap-2 text-sm text-slate-600">
                            <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                            <span>Suivi et gestion des modifications de code</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
